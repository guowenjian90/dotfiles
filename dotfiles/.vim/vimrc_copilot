" ========================================
" GitHub Copilot CLI Integration
" ========================================
" One command to copy @ reference with line range to clipboard

fu! SendToCopilot(visual)
  if a:visual
    let start_line = line("'<")
    let end_line = line("'>")
    let sel = getline("'<")[col("'<")-1 : col("'>")-1]
  else
    let start_line = line('.')
    let end_line = line('.')
    let sel = ''
  endif
  let ref = '@ ' . expand('%:p') . ':' . start_line . '-' . end_line
  let words = input('> ')
  if start_line == end_line && sel =~# '^\w\+$'
    let ref = ref . ' ' . sel
  endif
  let txt = empty(words) ? ref : ref . ' ' . words
  let pane_id = <SID>open_copilot_pane()
  call RunCommandInTmuxPane(txt, pane_id)
endf

fu! s:open_copilot_pane()
  let root = getcwd()
  let pane_id = <SID>find_pane_by_tool('claude')
  if pane_id == -1
    let pane_id = <SID>find_pane_by_tool('copilot')
  endif
  if pane_id == -1
    call RunCommandInNewPane("cd " . root . "; claude")
    let pane_id = <SID>find_pane_by_tool('claude')
  endif
  return pane_id
endfunction

fu! s:find_pane_by_tool(tool_pat)
  let panes = VimuxTmux("list-panes -F '#{pane_id} #{pane_pid}'")
  for pane in split(panes, "\n")
    let parts = split(pane, " ")
    if len(parts) < 2
      continue
    endif
    let child_pids = trim(system("pgrep -d, -P " . parts[1] . " 2>/dev/null"))
    let args = empty(child_pids) ? "" : system("ps -p " . child_pids . " -o args= 2>/dev/null")
    if args =~# a:tool_pat
      return parts[0]
    endif
  endfor
  return -1
endfunction

" Single keypress: select and copy current line
" nnoremap <leader>cg :call <SID>open_copilot_pane()<CR>

" Single keypress: copy visual selection  
nnoremap <leader>cc :<C-u>call SendToCopilot(0)<CR>
vnoremap <leader>cc :<C-u>call SendToCopilot(1)<CR>

