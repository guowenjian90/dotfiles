set statusline=%<%f\ %M\ %h%r%=%-10.(%l,%c%V\ %{eclim#project#util#ProjectStatusLine()}%)\ %P

fu! ScalaTestFile()
  let file = expand('%:p')
  if (stridx(file, "Test.scala") == -1)
    let new_file = substitute(file, "/main/", "/test/", "")
    let new_file = substitute(new_file, "\.scala$", "Test\.scala", "")
  else
    let new_file = substitute(file, "/test/", "/main/", "")
    let new_file = substitute(new_file, "Test\.scala", "\.scala", "")
  endif
  let exist = findfile(new_file)
  if (exist == new_file)
    exe "edit " new_file
  else
    echo 'can not find file '. new_file
  endif
endf
autocmd FileType scala nmap <Leader>ut :call ScalaTestFile()<CR>

fu! ScalaTest() 
  let project = eclim#project#util#GetCurrentProjectName()
  let file = eclim#project#util#GetProjectRelativeFilePath()
  let project_root = eclim#project#util#GetProject(project).path
  let class = substitute(file, "^src/test/scala/", "", "")
  let class = substitute(class, "^tst/", "", "")
  let class = split(class, '\.')[0]
  let class = substitute(class, "/", ".", "g")
  let currentLine   = getline(".")
  " let cmd = "eclim -command java -p " . project . " -c org.scalatest.tools.Runner " . " " . class
  let spec = matchlist(currentLine, '\v.*\s*[should|must]\s*\"(.*)\"\s*in.*')
  if (len(spec) >= 2)
    let spec = spec[1]
  endif
  if(empty(spec))
    let cmd = "cd " . project_root . "; java -cp " . project . "-classpath.jar" . ":bin/:bin/test:bin/main org.scalatest.tools.Runner -o -s " . class
  else
    let cmd = "cd " . project_root . "; java -cp " . project . "-classpath.jar" . ":bin/:bin/test:bin/main org.scalatest.tools.Runner -o -s " . class . " -z '" . spec . "'"
  endif
  call RunCommand(cmd)
endf
fu! RunScalaSpec()
  call EasyMotion#JK(0,2)
  call feedkeys("\<Space>tt")
endf
autocmd FileType scala nmap <Leader>ts :call RunScalaSpec()<CR>


fu! EclimJunit() 
  let project = eclim#project#util#GetCurrentProjectName()
  let file = eclim#project#util#GetProjectRelativeFilePath()
  let cmd = "eclim -command java_junit -p " . project . " -f " . file
  call RunCommand(cmd)
endf

fu! EclimJunitFind() 
  let project = eclim#project#util#GetCurrentProjectName()
  let file = eclim#project#util#GetProjectRelativeFilePath()
  let cmd = "eclim -command java_junit_find -p " . project . " -f " . file
  call RunCommand(cmd)
endf

fu! EclimRun(args) 
  let project = eclim#project#util#GetCurrentProjectName()
  let file = eclim#project#util#GetProjectRelativeFilePath()
  let class = substitute(file, "^src/main/java/", "", "")
  let class = substitute(class, "^src/main/scala/", "", "")
  let class = substitute(class, "^src/", "", "")
  let class = split(class, '\.')[0]
  let class = substitute(class, "/", ".", "g")
  let cmd = "eclim -command java -p " . project . " -c " . class . " " . a:args
  call RunCommand(cmd)
endf

fu! EclimNew(type, name) 
  let project = eclim#project#util#GetCurrentProjectName()
  let cmd = "eclim -command java_new -p " . project . " -t " . a:type . " -n " . a:name
  call RunCommand(cmd)
endf

fu! EclimSearch(type, name) 
  let cmd = "eclim -command java_search -x " . type . " -t all " " -p " . a:name
  call RunCommand(cmd)
endf
