set statusline=%<%f\ %M\ %h%r%=%-10.(%l,%c%V\ %{eclim#project#util#ProjectStatusLine()}%)\ %P

fu! TestFile(suffix)
  let ext = a:suffix
  let file = expand('%:p')
  if (stridx(file, "Test." . ext) == -1)
    let new_file = substitute(file, "/main/", "/test/", "")
    let new_file = substitute(new_file, "\." . ext . "$", "Test\." . ext, "")
  else
    let new_file = substitute(file, "/test/", "/main/", "")
    let new_file = substitute(new_file, "Test\." . ext, "\." . ext, "")
  endif
  let exist = findfile(new_file)
  if (exist == new_file)
    exe "edit " new_file
  else
    echo 'can not find file '. new_file
  endif
endf

fu! KotlinTest()
  let file = expand('%:p')
  let project_root = CurrentJavaPackagePath()
  let project = split(project_root, '/')[-1]
  let class = substitute(file, project_root, "", "")
  let class = substitute(class, "/src/test/kotlin/", "", "")
  let class = substitute(class, "/tst/", "", "")
  let class = split(class, '\.')[0]
  let class = substitute(class, "/", ".", "g")
  let currentLine = getline(".")
  let spec = matchlist(currentLine, '\v.*\s*[should|must]\s*\"(.*)\"\s*in.*')
  if (len(spec) >= 2)
    let spec = spec[1]
  endif
  if(empty(spec))
    let cmd = "cd " . project_root . "; java -cp " . project . "-classpath.jar " . "junit.textui.TestRunner " . class
  endif
  call RunCommand(cmd)
endf

fu! JavaRun(args)
  let file = expand('%:p')
  let project_root = CurrentJavaPackagePath()
  let project = split(project_root, '/')[-1]
  let class = substitute(file, project_root, "", "")
  let class = substitute(class, "/src/main/java/", "", "")
  let class = substitute(class, "/src/main/scala/", "", "")
  let class = substitute(class, "/src/main/kotlin/", "", "")
  let class = substitute(class, "/src/test/java/", "", "")
  let class = substitute(class, "/src/test/scala/", "", "")
  let class = substitute(class, "/src/test/kotlin/", "", "")
  let class = substitute(class, "/src/", "", "")
  let class = substitute(class, "/tst/", "", "")
  let class = split(class, '\.')[0]
  let class = substitute(class, "/", ".", "g")
  let cmd = "cd " . project_root . "; java -cp " . project . "-classpath.jar "  . class . a:args
  call RunCommand(cmd)
endf

fu! GetALEOutputPath()
  let project_root = CurrentJavaPackagePath()
  if project_root == '/'
    let project_root = '/tmp'
  endif
  let path = project_root . '/.ale/classes/'
  silent! call system('mkdir -p '. path)
  return path
endf

fu! GetSourcePaths(type)
  let project = eclim#project#util#GetCurrentProjectName()
  let project_root = eclim#project#util#GetProject(project).path
  return '.'
endf

fu! ScalaTest()
  let project = eclim#project#util#GetCurrentProjectName()
  let file = eclim#project#util#GetProjectRelativeFilePath()
  let project_root = eclim#project#util#GetProject(project).path
  let class = substitute(file, "^src/test/scala/", "", "")
  let class = substitute(class, "^tst/", "", "")
  let class = split(class, '\.')[0]
  let class = substitute(class, "/", ".", "g")
  let currentLine   = getline(".")
  " let cmd = "eclim -command java -p " . project . " -c org.scalatest.tools.Runner " . " " . class
  let spec = matchlist(currentLine, '\v.*\s*[should|must]\s*\"(.*)\"\s*in.*')
  if (len(spec) >= 2)
    let spec = spec[1]
  endif
  if(empty(spec))
    let cmd = "cd " . project_root . "; java -cp " . project . "-classpath.jar " . "org.scalatest.tools.Runner -o -s " . class
  else
    let cmd = "cd " . project_root . "; java -cp " . project . "-classpath.jar " . "org.scalatest.tools.Runner -o -s " . class . " -z '" . spec . "'"
  endif
  call RunCommand(cmd)
endf

fu! RunScalaSpec()
  call EasyMotion#JK(0,2)
  call feedkeys("\<Space>tt")
endf
autocmd FileType scala nmap <Leader>ts :call RunScalaSpec()<CR>


fu! EclimJunit()
  let project = eclim#project#util#GetCurrentProjectName()
  let file = eclim#project#util#GetProjectRelativeFilePath()
  let cmd = "eclim -command java_junit -p " . project . " -f " . file
  call RunCommand(cmd)
endf

fu! EclimJunitFind()
  let project = eclim#project#util#GetCurrentProjectName()
  let file = eclim#project#util#GetProjectRelativeFilePath()
  let cmd = "eclim -command java_junit_find -p " . project . " -f " . file
  call RunCommand(cmd)
endf

fu! EclimRun(args)
  let project = eclim#project#util#GetCurrentProjectName()
  let project_root = eclim#project#util#GetProject(project).path
  let file = eclim#project#util#GetProjectRelativeFilePath()
  let class = substitute(file, "^src/main/java/", "", "")
  let class = substitute(class, "^src/main/scala/", "", "")
  let class = substitute(class, "^src/main/kotlin/", "", "")
  let class = substitute(class, "^src/test/java/", "", "")
  let class = substitute(class, "^src/test/scala/", "", "")
  let class = substitute(class, "^src/test/kotlin/", "", "")
  let class = substitute(class, "^src/", "", "")
  let class = substitute(class, "^tst/", "", "")
  let class = split(class, '\.')[0]
  let class = substitute(class, "/", ".", "g")
  let cmd = "eclim -command java -p " . project . " -c " . class . " " . a:args
  call RunCommand(cmd)
endf

fu! EclimNew(type, name)
  let project = eclim#project#util#GetCurrentProjectName()
  let cmd = "eclim -command java_new -p " . project . " -t " . a:type . " -n " . a:name
  call RunCommand(cmd)
endf

fu! EclimSearch(type)
  let tag = expand("<cword>")
  let project = eclim#project#util#GetCurrentProjectName()
  let cmd = "eclim -command java_search -x " . a:type . " -t all -p " . project . " " . tag
  call RunCommand(cmd)
endf

