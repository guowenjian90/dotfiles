"
" for eclim
let g:EclimCompletionMethod = 'omnifunc'
nmap <Leader>lf :LocateFile<CR>
nmap <Leader>pb :ProjectBuild<CR>
nmap <Leader>pl :ProjectList<CR>
nmap <Leader>pe :ProjectProblems!<CR>
nmap <Leader>pp :ProjectProblems<CR>
nmap <Leader>po :ProjectOpen<CR>
nmap <Leader>pc :ProjectClose<CR>
nmap <Leader>pr :ProjectRefreshAll<CR>
autocmd FileType java setlocal omnifunc=eclim#java#complete#CodeComplete
autocmd FileType scala setlocal omnifunc=eclim#scala#complete#CodeComplete
autocmd FileType scala imap <C-i> <C-X><C-O>
" autocmd FileType scala imap <C-n> <C-X><C-N>
" autocmd FileType scala imap <C-p> <C-X><C-P>
autocmd FileType scala nmap <C-]> :ScalaSearch<CR>
autocmd FileType scala nmap <Leader>jo :ScalaImport<CR>
autocmd FileType scala nmap <Leader>tt :call EclimJunit()<CR>
autocmd FileType scala nmap <Leader>ut :call EclimJunitFind()<CR>
autocmd FileType scala nmap <Leader>rn :call EclimRun()<CR>
autocmd FileType scala nmap <Leader>jnc :call EclimNew('class', input(''))<CR>
autocmd FileType scala nmap <Leader>jni :call EclimNew('interface', input(''))<CR>
autocmd FileType scala nmap <Leader>jna :call EclimNew('@interface', input(''))<CR>
autocmd FileType scala nmap <Leader>jn@ :call EclimNew('abstract', input(''))<CR>
autocmd FileType scala nmap <Leader>jne :call EclimNew('enum', input(''))<CR>
autocmd FileType scala nmap <Leader>jnt :call EclimNew('class', expand('<cword>') . "Test")<CR>
autocmd FileType java imap <C-i> <C-X><C-O>
autocmd FileType java imap <C-n> <C-X><C-N>
autocmd FileType java imap <C-p> <C-X><C-P>
autocmd FileType java nmap <C-]> :JavaSearchContext<CR>
autocmd FileType java nmap <Leader>jnc :JavaNew class 
autocmd FileType java nmap <Leader>jni :JavaNew interface 
autocmd FileType java nmap <Leader>jna :JavaNew abstract 
autocmd FileType java nmap <Leader>jn@ :JavaNew @interface 
autocmd FileType java nmap <Leader>jne :JavaNew enum 
autocmd FileType java nmap <Leader>jnt :execute "JavaNew class " . expand('<cword>') . "Test"<CR>
autocmd FileType java nmap <Leader>jc :JavaCorrect <CR>
autocmd FileType java nmap <Leader>jsc :JavaSearchContext<CR>
autocmd FileType java nmap <Leader>jsi :JavaSearch -x implementors<CR>
autocmd FileType java nmap <Leader>jsr :JavaSearch -x references<CR>
autocmd FileType java nmap <Leader>jh<CR> :JavaCallHierarchy<CR>
autocmd FileType java nmap <Leader>jh! :JavaCallHierarchy!<CR>
autocmd FileType java nmap <Leader>jr :JavaRename<Space>
autocmd FileType java nmap <Leader>jm :JavaMove<Space>
autocmd FileType java nmap <Leader>jf :JavaFormat<CR>
autocmd FileType java nmap <Leader>jo :JavaImportOrganize<CR>
autocmd FileType java nmap <Leader>ji :JavaImpl<CR>
autocmd FileType java nmap <Leader>jg<CR> :JavaGet<CR>
autocmd FileType java nmap <Leader>jgs :JavaGetSet<CR>
autocmd FileType java nmap <Leader>jdg :JavaDelegate<CR>
autocmd FileType java nmap <Leader>tt :JUnit<CR>
autocmd FileType java nmap <Leader>ut :JUnitFind<CR>
autocmd FileType java nmap <Leader>jtt :call EclimJunit()<CR>
autocmd FileType java nmap <Leader>jui :JUnitImpl<CR>
autocmd FileType java nmap <Leader>ud :RefactorUndo<CR>
autocmd FileType java nmap <Leader>rd :RefactorRedo<CR>
autocmd FileType java nmap <Leader>ds<CR> :JavaDebugStatus<CR>
autocmd FileType java nmap <Leader>dst :JavaDebugStart localhost 1044<CR>
autocmd FileType java nmap <Leader>dsp :JavaDebugStop<CR>
autocmd FileType java nmap <Leader>dso :JavaDebugStep over<CR>
autocmd FileType java nmap <Leader>dsi :JavaDebugStep into<CR>
autocmd FileType java nmap <Leader>dsr :JavaDebugStep return<CR>
autocmd FileType java nmap <Leader>dbt :JavaDebugBreakpointToggle<CR>
autocmd FileType java nmap <Leader>dbr :JavaDebugBreakpointRemove<CR>
autocmd FileType java nmap <Leader>dbl :JavaDebugBreakpointsList<CR>
autocmd FileType java nmap <Leader>dtr :JavaDebugThreadResume<CR>
autocmd FileType java nmap <Leader>dta :JavaDebugThreadResumeAll<CR>
autocmd FileType java nmap <F3> <Leader>jsc
autocmd FileType java nmap <F4> <Leader>dst <bar> <Leader>jds
autocmd FileType java nmap <F5> <Leader>dsi <bar> <Leader>jds
autocmd FileType java nmap <F6> <Leader>dso <bar> <Leader>jds
autocmd FileType java nmap <F7> <Leader>dsr <bar> <Leader>jds
autocmd FileType java nmap <F8> <Leader>dbt <bar> <Leader>jds
set statusline=%<%f\ %M\ %h%r%=%-10.(%l,%c%V\ %{eclim#project#util#ProjectStatusLine()}%)\ %P

fu! EclimJunit() 
  let project = eclim#project#util#GetCurrentProjectName()
  let file = eclim#project#util#GetProjectRelativeFilePath()
  let cmd = "eclim -command java_junit -p " . project . " -f " . file
  call RunCommand(cmd)
endf

fu! EclimJunitFind() 
  let project = eclim#project#util#GetCurrentProjectName()
  let file = eclim#project#util#GetProjectRelativeFilePath()
  let cmd = "eclim -command java_junit_find -p " . project . " -f " . file
  call RunCommand(cmd)
endf

fu! EclimRun() 
  let project = eclim#project#util#GetCurrentProjectName()
  let file = eclim#project#util#GetProjectRelativeFilePath()
  let class = substitute(file, "src/", "", "")
  let class = split(class, '\.')[0]
  let class = substitute(class, "/", ".", "g")
  let cmd = "eclim -command java -p " . project . " -c " . class 
  call RunCommand(cmd)
endf

fu! EclimNew(type, name) 
  let project = eclim#project#util#GetCurrentProjectName()
  let cmd = "eclim -command java_new -p " . project . " -t " . a:type . " -n " . a:name
  call RunCommand(cmd)
endf

fu! EclimSearch(type, name) 
  let cmd = "eclim -command java_search -x " . type . " -t all " " -p " . a:name
  call RunCommand(cmd)
endf
