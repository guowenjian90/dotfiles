" vimux
fu! GetVisualText()
  try
    let a_save = @a
    normal! gv"ay
    return @a
  finally
    let @a = a_save
  endtry
endf

fu! RunCommandVis() range
  let cmd = GetVisualText()
  if exists('$TMUX')
    exe "VimuxRunCommand \"" . cmd . "\""
  end
endf
vmap <Leader>rn :call RunCommandVis()<CR>

fu! RunCommand(cmd)
  if exists('$TMUX')
    exe "VimuxRunCommand \"" . a:cmd . "\""
  else
    exe "!" . a:cmd
  end
endf

nmap <Leader>rr :VimuxRunLastCommand<CR>
let g:VimuxOrientation = 'v'

fu! TaggleQuickList()
  let qf = bufexists("[Location List]")
  if (qf == 1)
    exe "close"
  else
    exe "copen"
  endif
endf
nmap ql :call TaggleQuickList()<CR>
