fu! MoveToTag()
  call EasyMotion#WB(0,2)
  call feedkeys("\<C-]>")
endf
fu! IMoveToTag()
  call EasyMotion#WB(0,2)
  call feedkeys("\<C-o>")
  call feedkeys("\<C-]>")
endf
nmap mg :call MoveToTag()<CR>
imap mg<CR> <C-o>:call IMoveToTag()<CR>

fu! MoveToWord()
  call EasyMotion#JK(0,2)
  call feedkeys("\ml")
endf
fu! IMoveToWord()
  call EasyMotion#JK(0,2)
  call feedkeys("\ml")
  call feedkeys("\<CR>")
endf
nmap mm :call MoveToWord()<CR>
imap mm<CR> <C-o>:call IMoveToWord()<CR>

