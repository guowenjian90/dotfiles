fu! MakeTags() "rebuild tags
  let dir = getcwd()
  let savedir = getcwd()
  while (dir != '/')
    let scopefile = dir . '/' . "make_tags.sh"
    if filereadable(scopefile)
      exe "!sh ./make_tags.sh "
      break
    else
      cd ..
      let dir = getcwd()
    endif
  endw
  exe "cd " savedir
endf
nmap <Leader>mtg :call MakeTags()<CR>

